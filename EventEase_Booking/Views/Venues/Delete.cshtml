@model EventEase_Booking.Models.Venue

@{
    ViewData["Title"] = "Delete";
    // Check if there are any linked bookings
    bool hasBookings = Model.Bookings != null && Model.Bookings.Any();
}

<h1>Delete Venue</h1>
@* --- BLOCKED STATE: Has Active Reservations --- *@
@if (hasBookings)
{
    <div class="card shadow-sm mb-4 border-info">
        <div class="card-header bg-navy text-white" style="background-color: #001f3f;">
            <h3 class="card-title mb-0"><i class="fas fa-lock me-2"></i> Deletion Blocked</h3>
        </div>
        <div class="card-body">
            <div class="alert alert-warning border-warning shadow-sm">
                <i class="fas fa-exclamation-triangle me-2"></i>
                <strong>Notice:</strong> You cannot delete <b>@Model.VenueName</b> because it is currently linked to <b>@Model.Bookings.Count()</b> active reservation(s). 
                Please remove these bookings first.
            </div>

            <h5>Linked Reservations:</h5>
            <table class="table table-sm table-hover mt-3">
                <thead class="table-light">
                    <tr>
                        <th>Booking ID</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in Model.Bookings)
                    {
                        <tr>
                            <td>@booking.BookingID</td>
                            <td>@booking.StartDate.ToString("g")</td>
                            <td>@booking.EndDate.ToString("g")</td>
                            <td>
                                <a asp-controller="Bookings" asp-action="Delete" asp-route-id="@booking.BookingID" class="text-danger">Remove</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="mt-4">
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </div>
    </div>
}
@* --- SAFE STATE: No Reservations, Can Delete --- *@
else
{
    <div class="card shadow-sm border-danger">
        <div class="card-header bg-danger text-white">
            <h3 class="card-title mb-0"><i class="fas fa-trash-alt me-2"></i> Confirm Deletion</h3>
        </div>
        <div class="card-body">
            <p class="lead">Are you sure you want to delete this venue? This action cannot be undone.</p>
            
            <dl class="row">
                <dt class="col-sm-3">Venue Name</dt>
                <dd class="col-sm-9">@Model.VenueName</dd>

                <dt class="col-sm-3">Location</dt>
                <dd class="col-sm-9">@Model.Location</dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="VenueID" />
                <button type="submit" class="btn btn-danger shadow-sm">
                    <i class="fas fa-trash me-1"></i> Delete Permanentely
                </button> |
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
    }