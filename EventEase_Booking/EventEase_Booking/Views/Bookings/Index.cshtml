@model IEnumerable<EventEase_Booking.Models.Booking>

@{
    ViewData["Title"] = "Index";
}

<h1>Bookings</h1>
<p>
    @* --- 1. ALERTS SECTION --- *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="fas fa-check-circle me-2"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <p>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="fas fa-plus me-1"></i> Make a Reservation
        </a>
    </p>

    @* --- 2. SEARCH BAR (Visible to everyone) --- *@
    <div class="container mt-4 mb-4">
        <form asp-action="Index" method="get">
            <div class="d-flex gap-3 align-items-center flex-wrap p-4 bg-white shadow-sm rounded border">
                <div class="flex-grow-1" style="min-width:250px;">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="fas fa-search text-muted"></i>
                        </span>
                        <input type="text"
                               name="searchQuery"
                               value="@ViewData["SearchQuery"]"
                               class="form-control border-start-0"
                               placeholder="Search by Booking ID or Event Name..." />
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4 shadow-sm">
                        <i class="fas fa-search me-1"></i> Search
                    </button>

                    @if (!string.IsNullOrEmpty(ViewData["SearchQuery"]?.ToString()))
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 shadow-sm">
                            <i class="fas fa-times me-1"></i> Clear
                        </a>
                    }
                </div>
            </div>

            @if (!string.IsNullOrEmpty(ViewData["SearchQuery"]?.ToString()))
            {
                <p class="mt-2 text-muted small ms-1">
                    <i class="fas fa-filter me-1"></i>
                    Showing results for: <strong>"@ViewData["SearchQuery"]"</strong>
                    (@Model.Count() found)
                </p>
            }
        </form>
    </div>

    @* --- 3. DATA SECTION --- *@
    @if (!Model.Any())
    {
        <div class="alert alert-info shadow-sm rounded border-info mt-4">
            <i class="fas fa-calendar-alt me-2"></i>
            <strong>No Bookings Found:</strong> There are no reservations matching your search.
        </div>
    }
    else
    {
        <table class="table table-striped table-hover table-bordered shadow-sm rounded mt-4">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.Venue)</th>
                    <th>@Html.DisplayNameFor(model => model.Event)</th>
                    <th>@Html.DisplayNameFor(model => model.StartDate)</th>
                    <th>@Html.DisplayNameFor(model => model.EndDate)</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @if (item.Venue != null)
                            {
                                @item.Venue.VenueName
                            }
                            else
                            {
                                <span class="text-danger">No Venue Assigned</span>
                            }
                        </td>
                        <td>
                            @if (item.Event != null)
                            {
                                @item.Event.EventName
                            }
                            else
                            {
                                <span class="text-danger">No Event Assigned</span>
                            }
                        </td>
                        <td>@Html.DisplayFor(modelItem => item.StartDate)</td>
                        <td>@Html.DisplayFor(modelItem => item.EndDate)</td>
                        <td>
                            <div class="btn-group" role="group">
                                <a asp-action="Edit" asp-route-id="@item.BookingID" class="btn btn-warning btn-sm">Edit</a>
                                <a asp-action="Details" asp-route-id="@item.BookingID" class="btn btn-info btn-sm text-white">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.BookingID" class="btn btn-danger btn-sm">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

   
    }