@model IEnumerable<EventEase_Booking.Models.Event>

@{
    ViewData["Title"] = "Index";
}

<h1>Events</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<div class="container mt-4 mb-4">
    <!-- Advanced Filter Panel -->
    <form asp-action="Index" method="get" class="card p-4 shadow-sm">
        <h5 class="mb-3">Advanced Event Search</h5>
        <div class="row g-3 align-items-end">
            
            <!-- Text Search -->
            <div class="col-lg-3 col-md-6">
                <label class="form-label">Search Keyword</label>
                <input type="text" name="searchQuery" value="@ViewData["SearchQuery"]" class="form-control" placeholder="Event name...">
            </div>

            <!-- Category Dropdown -->
            <div class="col-lg-3 col-md-6">
                <label class="form-label">Category</label>
                <select name="categoryId" class="form-select" asp-items="@ViewBag.CategoryList">
                    <option value="">-- All Categories --</option>
                </select>
            </div>

            <!-- Start Date -->
            <div class="col-lg-2 col-md-4">
                <label class="form-label">From</label>
                <input type="date" name="startDate" value="@ViewData["StartDate"]" class="form-control">
            </div>

            <!-- End Date -->
            <div class="col-lg-2 col-md-4">
                <label class="form-label">To</label>
                <input type="date" name="endDate" value="@ViewData["EndDate"]" class="form-control">
            </div>

            <!-- Action Buttons -->
            <div class="col-lg-2 col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100">Apply</button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
            </div>
        </div>

        <!-- Active Filters Indicator -->
        @if (ViewData["SearchQuery"] != null || ViewData["CategoryId"] != null || ViewData["StartDate"] != null || ViewData["EndDate"] != null)
        {
            <div class="mt-3 pt-3 border-top">
                <span class="text-muted small me-2">Active Filters:</span>
                
                @if (ViewData["SearchQuery"] != null)
                {
                    <span class="badge bg-info text-dark me-1">Keyword: @ViewData["SearchQuery"]</span>
                }
                @if (ViewData["StartDate"] != null)
                {
                    <span class="badge bg-secondary me-1">From: @ViewData["StartDate"]</span>
                }
                @if (ViewData["EndDate"] != null)
                {
                    <span class="badge bg-secondary me-1">To: @ViewData["EndDate"]</span>
                }
            </div>
        }
    </form>
</div>

<table class="table table-striped table-hover table-bordered shadow-sm rounded">
    @*
    ================Code Attribution==============
    Bootstrap Tables
    Author: Tutorial Republic
    Link: https://www.tutorialrepublic.com/twitter-bootstrap-tutorial/bootstrap-tables.php 
    Date Accessed: 6 May 2026
    ================Code Attribution==============

 *@
    <thead class="table-dark">
        <tr>
           
            <th>Event Name</th>
            <th>Category</th>
            <th>Image</th>
            <th>Actions</th>

        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
    {
        <tr>
            <td colspan="4" class="text-center text-muted" style="padding: 20px;">
                <em>No events found matching your search criteria. Please try a different keyword.</em>
            </td>
        </tr>
    }
    else
    {
        @foreach (var item in Model)
        {
            <tr>
                <td class="align-middle">
                    @item.EventName
                </td>
            
                <td class="align-middle">
                    @item.EventType?.Name
                </td>
            
                <td class="align-middle">
                    @* ========================Code Attribution====================
                   Bootstrap Image Thumbnails and Razor IF logic    
                   Author: Bootstrap Team / Microsoft    
                   Link: https://getbootstrap.com/docs/5.0/content/images/#image-thumbnails    
                   Date accessed: 7 May 2026    
                   ========================Code Attribution==================== *@
                    @if (!string.IsNullOrEmpty(item.ImageURL))
                    {
                        <img src="@item.ImageURL" alt="@item.EventName" style="width: 80px; height: auto;" class="img-thumbnail shadow-sm" />
                    }
                    else
                    {
                        <span class="text-muted fst-italic">No Image</span>
                    }
                </td>
            
                <td class="align-middle">
                    <a asp-action="Edit" asp-route-id="@item.EventID" class="btn btn-warning btn-sm">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.EventID" class="btn btn-info btn-sm">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.EventID" class="btn btn-danger btn-sm">Delete</a>
                
                    @* ================Code Attribution==============
                   Google AI Overview                    
                   Author: Google                    
                   Link: https://www.google.com/search?q=how+to+make+links+look+like+buttons+in+mvc...                    
                   Date Accessed: 6 May 2026                    
                   ================Code Attribution============== *@
                </td>
            </tr>
        } 
        }
    </tbody>
</table>
